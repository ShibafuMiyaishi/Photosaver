# Root-level environment template.
# Copy to .env and fill in real values. NEVER commit .env.
#
# Most stack variables live in immich/.env — this root file is for
# cross-cutting settings (paths, MCP tokens) used outside docker-compose.

# --------------------------------------------------
# Photo storage path (absolute path on the host)
# --------------------------------------------------
# Windows example: E:/Photo
# Linux/WSL2 example: /mnt/e/Photo
# Must exist and be writable. Must be added to Docker Desktop File Sharing.
PHOTO_STORAGE_PATH=E:/Photo

# --------------------------------------------------
# GitHub token for the .claude/mcp.json "github" server (optional)
# --------------------------------------------------
# Create a fine-grained PAT with read/write scoped ONLY to ShibafuMiyaishi/Photosaver.
# Scopes: contents:rw, issues:rw, pull_requests:rw.
# https://github.com/settings/personal-access-tokens/new
GITHUB_PERSONAL_ACCESS_TOKEN=
