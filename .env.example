# Root-level environment template.
# Copy to .env and fill in real values. NEVER commit .env.
#
# Most stack variables live in immich/.env — this root file is for
# cross-cutting settings (paths, MCP tokens) used outside docker-compose.

# --------------------------------------------------
# Photo storage path (absolute path on the host)
# --------------------------------------------------
# Windows example: E:/Photo
# Linux/WSL2 example: /mnt/e/Photo
# Must exist and be writable. Must be added to Docker Desktop File Sharing.
PHOTO_STORAGE_PATH=E:/Photo

# --------------------------------------------------
# GitHub token for the .claude/mcp.json "github" server (optional)
# --------------------------------------------------
# Create a fine-grained PAT with read/write scoped ONLY to ShibafuMiyaishi/Photosaver.
# Scopes: contents:rw, issues:rw, pull_requests:rw.
# https://github.com/settings/personal-access-tokens/new
GITHUB_PERSONAL_ACCESS_TOKEN=

# --------------------------------------------------
# Cloudflare Tunnel automation (used by scripts/cloudflare-setup.mjs and cloudflare-verify.mjs)
# The tunnel TOKEN itself is stored in immich/.env as CLOUDFLARE_TUNNEL_TOKEN
# (auto-populated by the setup script — do not hand-edit it here).
# --------------------------------------------------
# Cloudflare API token with these scopes:
#   Account > Cloudflare Tunnel > Edit
#   Zone    > DNS > Edit
#   Zone    > Zone > Read
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID (right sidebar of any Cloudflare Dashboard page).
CLOUDFLARE_ACCOUNT_ID=

# Apex domain registered in Cloudflare DNS (no subdomain).
CLOUDFLARE_ZONE_NAME=yourdomain.com

# Public hostname to expose Photosaver on (subdomain of ZONE_NAME).
CLOUDFLARE_HOSTNAME=photos.yourdomain.com
