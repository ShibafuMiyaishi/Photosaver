# Copy to immich/.env and fill in real values. NEVER commit immich/.env.

# --------------------------------------------------
# Photo storage path (absolute path on the host)
# Bind-mounted to:
#   - immich-server:   ${PHOTO_STORAGE_PATH}/immich-library -> /usr/src/app/upload
#   - album-guard:     ${PHOTO_STORAGE_PATH}/guard          -> /app/data
# --------------------------------------------------
# Windows example: E:/Photo
# Linux/WSL2 example: /mnt/e/Photo
PHOTO_STORAGE_PATH=E:/Photo

# --------------------------------------------------
# Immich
# See https://immich.app/docs/install/environment-variables
# --------------------------------------------------
IMMICH_VERSION=release
UPLOAD_LOCATION=/usr/src/app/upload

# Postgres image (pgvector + vectorchord 対応)。
# 上流 Immich の docker-compose.yml と整合するタグに追従する。
IMMICH_DB_IMAGE=ghcr.io/immich-app/postgres:14-vectorchord0.4.3-pgvectors0.2.0

# pgvector / pgvectorchord extension の切り替え(v2.x 以降は vectorchord が既定)。
DB_VECTOR_EXTENSION=vectorchord

DB_HOSTNAME=immich-db
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
# Use a strong password. Generate with: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

REDIS_HOSTNAME=immich-redis

# --------------------------------------------------
# album-guard (HPSS Phase 11)
# --------------------------------------------------
# Generate with: openssl rand -hex 32
GUARD_JWT_SECRET=CHANGE_ME_32_CHAR_MIN_RANDOM_HEX_STRING

# Default JWT lifetime. Per-album overrides live inside album-passwords.json.
GUARD_JWT_EXPIRES_IN=24h

# album-guard listening port (inside the compose network; not exposed publicly by default)
GUARD_PORT=3000

# Path to album-passwords.json INSIDE the container (bind-mounted from the drive)
GUARD_PASSWORDS_FILE=/app/data/album-passwords.json

# Morgan log format: combined | dev | tiny
GUARD_LOG_FORMAT=combined

# --------------------------------------------------
# 外部アクセスは Tailscale で行う(ドメイン不要・無料)。
# セットアップ手順: docs/tailscale.md
# --------------------------------------------------
